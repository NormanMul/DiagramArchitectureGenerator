    { "id": "saas",    "label": "SaaS sources",          "icon_id": "all-resources",        "tier": "sources" },
    { "id": "df",      "label": "Data Factory",          "icon_id": "data-factories",      "tier": "ingest" },
    { "id": "adls",    "label": "ADLS Gen2",             "icon_id": "data-lake-storage-gen1","tier": "storage" },
    { "id": "syn",     "label": "Synapse SQL Pool",      "icon_id": "azure-synapse-analytics",   "tier": "compute" },
    { "id": "spark",   "label": "Synapse Spark",         "icon_id": "azure-synapse-analytics",   "tier": "compute" },
    { "id": "aas",     "label": "Analysis Services",     "icon_id": "analysis-services",   "tier": "compute" },
    { "id": "pbi",     "label": "Power BI",              "icon_id": "power-bi-embedded",            "tier": "consume" }
