# Normalize line endings to LF.
* text=auto eol=lf

# Binary types
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.zip  binary

# SVG is text but treat as binary to avoid line-ending munging of icon files.
*.svg binary

# Lock files
pnpm-lock.yaml -diff
uv.lock        -diff
